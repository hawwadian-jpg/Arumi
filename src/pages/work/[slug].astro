---
import WorkDetailPage from "@/components/WorkDetailPage.astro";
import { getContent, type Work } from "@/content/site";

export function getStaticPaths() {
  return getContent("ru").works.map((work) => ({ params: { slug: work.slug }, props: { work } }));
}

type Props = { work: Work };
const { work } = Astro.props;
---

<WorkDetailPage locale="ru" work={work} />
